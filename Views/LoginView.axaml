<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:conv="using:AvaloniaApplication1.Converters"
             mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="720"
             x:Class="AvaloniaApplication1.Views.LoginView"
             HorizontalAlignment="Center" VerticalAlignment="Center">

    <Border Background="{DynamicResource SystemAltHighColor}" CornerRadius="10" Padding="30" BorderBrush="{DynamicResource SystemBaseMediumLowColor}" BorderThickness="1">
        <StackPanel Spacing="15" Width="300">
            <!-- Header - Uses accent color -->
            <TextBlock Text="🦀 Морепродукты" 
                      FontSize="24" 
                      FontWeight="Bold" 
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"
                      Foreground="{DynamicResource SystemAccentColor}"/>

            <!-- Error Message -->
            <TextBlock Text="{Binding ErrorMessage}" 
                      Foreground="{StaticResource DangerBrush}" 
                      TextWrapping="Wrap"
                      IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Login Form -->
            <StackPanel IsVisible="{Binding IsLoginMode}" Spacing="10">
                <TextBlock Text="Вход" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemBaseHighColor}"/>
                
                <TextBox Watermark="Номер телефона" 
                        Text="{Binding Phone}"/>
                
                <Button Content="Войти" HorizontalAlignment="Center"
                       Command="{Binding LoginCommand}"
                       IsEnabled="{Binding !IsLoading}"
                       Classes="Primary"/>
                
                <TextBlock Text="Нет аккаунта?" HorizontalAlignment="Center" Foreground="{DynamicResource SystemBaseHighColor}"/>
                <TextBlock Text="Обратитесь к администратору" HorizontalAlignment="Center" Foreground="{DynamicResource SystemBaseMediumColor}" FontSize="12"/>
                <Button Content="Связаться с поддержкой" HorizontalAlignment="Center"
                       Command="{Binding SwitchToRegisterCommand}"
                       IsVisible="False"/>
                
            </StackPanel>

            <!-- Registration Form - Disabled for security -->
            <StackPanel IsVisible="{Binding !IsLoginMode}" Spacing="10" IsEnabled="False">
                <TextBlock Text="Регистрация недоступна" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemBaseMediumColor}"/>
                
                <TextBlock Text="Для создания учётной записи обратитесь к администратору" 
                          TextWrapping="Wrap"
                          HorizontalAlignment="Center"
                          Foreground="{DynamicResource SystemBaseMediumColor}"
                          FontSize="12"
                          Margin="0,10"/>
                
                <TextBox Watermark="Номер телефона" 
                        Text="{Binding Phone}"
                        IsEnabled="False"/>
                
                <TextBox Watermark="Фамилия" 
                        Text="{Binding LastName}"
                        IsEnabled="False"/>
                
                <TextBox Watermark="Имя" 
                        Text="{Binding FirstName}"
                        IsEnabled="False"/>
                
                <TextBox Watermark="Отчество (необязательно)" 
                        Text="{Binding MiddleName}"
                        IsEnabled="False"/>
                
                <Button Content="Регистрация недоступна" 
                       Command="{Binding RegisterCommand}"
                       IsEnabled="False"
                       Classes="Primary"/>
                
                <TextBlock Text="Уже есть аккаунт?" HorizontalAlignment="Center" Foreground="{DynamicResource SystemBaseHighColor}"/>
                <Button Content="Войти" 
                       Command="{Binding SwitchToLoginCommand}"
                       Classes="Secondary"/>
            </StackPanel>

            <!-- Verification Code Form -->
            <StackPanel IsVisible="{Binding ShowVerificationStep}" Spacing="10">
                <TextBlock Text="Подтверждение" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="{DynamicResource SystemBaseHighColor}"/>
                
                <TextBlock Text="Код отправлен в Telegram" 
                          TextWrapping="Wrap"
                          HorizontalAlignment="Center"
                          Foreground="{DynamicResource SystemBaseHighColor}"/>
                
                <TextBox Watermark="Код подтверждения" 
                        Text="{Binding VerificationCode}"
                        HorizontalAlignment="Center"
                        MaxLength="6"/>
                
                <Button Content="Подтвердить" 
                       Command="{Binding VerifyCodeCommand}"
                       IsEnabled="{Binding !IsLoading}"
                       Classes="Primary"
                       HorizontalAlignment="Center"/>
                
                <Button Content="Отмена" 
                       Command="{Binding SwitchToLoginCommand}"
                       Classes="Secondary"
                       HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Loading Indicator -->
            <StackPanel IsVisible="{Binding IsLoading}" 
                       Orientation="Horizontal" 
                       HorizontalAlignment="Center"
                       Spacing="10">
                <ProgressBar IsIndeterminate="True" Width="100"/>
                <TextBlock Text="Загрузка..." Foreground="{DynamicResource SystemBaseHighColor}"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
