<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="300"
             x:Class="AvaloniaApplication1.Views.LoginView"
             HorizontalAlignment="Center" VerticalAlignment="Center">

    <Border Background="#F9FAFB" CornerRadius="10" Padding="30" BorderBrush="#D1D5DB" BorderThickness="1">
        <StackPanel Spacing="15" Width="300">
            <!-- Header - Matching mobile app blue -->
            <TextBlock Text="🦀 Морепродукты" 
                      FontSize="24" 
                      FontWeight="Bold" 
                      HorizontalAlignment="Center"
                      Margin="0,0,0,10"
                      Foreground="#3B82F6"/>

            <!-- Error Message -->
            <TextBlock Text="{Binding ErrorMessage}" 
                      Foreground="Red" 
                      TextWrapping="Wrap"
                      IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

            <!-- Login Form -->
            <StackPanel IsVisible="{Binding IsLoginMode}" Spacing="10">
                <TextBlock Text="Вход" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Black"/>
                
                <TextBox Watermark="Номер телефона" 
                        Text="{Binding Phone}"/>
                
                <Button Content="Войти" HorizontalAlignment="Center"
                       Command="{Binding LoginCommand}"
                       IsEnabled="{Binding !IsLoading}"
                       Classes="Primary"/>
                
                <TextBlock Text="Нет аккаунта?" HorizontalAlignment="Center" Foreground="Black"/>
                <TextBlock Text="Обратитесь к администратору" HorizontalAlignment="Center" Foreground="#6B7280" FontSize="12"/>
                <Button Content="Связаться с поддержкой" HorizontalAlignment="Center"
                       Command="{Binding SwitchToRegisterCommand}"
                       IsVisible="False"/>
                
                <Separator/>
                
                <Button Content="Войти через Telegram" 
                       Command="{Binding RequestCodeCommand}"
                       IsEnabled="{Binding !IsLoading}"/>
            </StackPanel>

            <!-- Registration Form - Disabled for security -->
            <StackPanel IsVisible="{Binding !IsLoginMode}" Spacing="10" IsEnabled="False">
                <TextBlock Text="Регистрация недоступна" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="#6B7280"/>
                
                <TextBlock Text="Для создания учётной записи обратитесь к администратору" 
                          TextWrapping="Wrap"
                          HorizontalAlignment="Center"
                          Foreground="#6B7280"
                          FontSize="12"
                          Margin="0,10"/>
                
                <TextBox Watermark="Номер телефона" 
                        Text="{Binding Phone}"
                        IsEnabled="False"/>
                
                <TextBox Watermark="Фамилия" 
                        Text="{Binding LastName}"
                        IsEnabled="False"/>
                
                <TextBox Watermark="Имя" 
                        Text="{Binding FirstName}"
                        IsEnabled="False"/>
                
                <TextBox Watermark="Отчество (необязательно)" 
                        Text="{Binding MiddleName}"
                        IsEnabled="False"/>
                
                <Button Content="Регистрация недоступна" 
                       Command="{Binding RegisterCommand}"
                       IsEnabled="False"
                       Classes="Primary"/>
                
                <TextBlock Text="Уже есть аккаунт?" HorizontalAlignment="Center" Foreground="Black"/>
                <Button Content="Войти" 
                       Command="{Binding SwitchToLoginCommand}"/>
            </StackPanel>

            <!-- Verification Code Form -->
            <StackPanel IsVisible="{Binding ShowVerificationStep}" Spacing="10">
                <TextBlock Text="Подтверждение" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Black"/>
                
                <TextBlock Text="Код отправлен в Telegram" 
                          TextWrapping="Wrap"
                          HorizontalAlignment="Center"
                          Foreground="Black"/>
                
                <TextBox Watermark="Код подтверждения" 
                        Text="{Binding VerificationCode}"
                        HorizontalAlignment="Center"/>
                
                <Button Content="Подтвердить" 
                       Command="{Binding VerifyCodeCommand}"
                       IsEnabled="{Binding !IsLoading}"
                       Classes="Primary"/>
                
                <Button Content="Отмена" 
                       Command="{Binding SwitchToLoginCommand}"/>
            </StackPanel>

            <!-- Loading Indicator -->
            <StackPanel IsVisible="{Binding IsLoading}" 
                       Orientation="Horizontal" 
                       HorizontalAlignment="Center"
                       Spacing="10">
                <ProgressBar IsIndeterminate="True" Width="100"/>
                <TextBlock Text="Загрузка..." Foreground="Black"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
