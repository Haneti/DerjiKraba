<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="using:AvaloniaApplication1.Controls"
             xmlns:converters="using:AvaloniaApplication1.Converters"
             xmlns:ViewModels="using:AvaloniaApplication1.ViewModels"
             xmlns:system="clr-namespace:System;assembly=System.Runtime"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="AvaloniaApplication1.Views.ProductsView">

    <UserControl.Resources>
        <converters:BoolToBorderBrushConverter x:Key="BorderBrushConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*" Margin="20">
        <!-- Header - Matching mobile app style -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,20">
            <TextBlock Text="📦 Управление товарами" 
                      FontSize="24" 
                      FontWeight="Bold"
                      Foreground="{DynamicResource SystemBaseHighColor}"/>
            
            <Button Grid.Column="1" 
                   Content="+ Добавить товар" 
                   Command="{Binding StartCreateCommand}"
                   Classes="Primary"
                   Background="#3B82F6"
                   Foreground="White"/>
        </Grid>

        <!-- Main Content - Clean white background -->
        <Grid Grid.Row="1" ColumnDefinitions="*,Auto">
            <!-- Products Gallery List -->
            <Border Grid.Column="0" 
                   BorderBrush="{DynamicResource SystemBaseMediumLowColor}" 
                   BorderThickness="1" 
                   CornerRadius="5"
                   Margin="0,0,10,0"
                   Background="{DynamicResource SystemAltHighColor}">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Products}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="220" Height="360" Margin="8" 
                                        CornerRadius="8" BorderThickness="2"
                                        BorderBrush="Transparent"
                                        Background="{DynamicResource SystemAltHighColor}" BoxShadow="0 2 4 #20000000"
                                        Cursor="Hand">
                                    <Border.Styles>
                                        <Style Selector="Border:pointerover">
                                            <Setter Property="BorderBrush" Value="#3B82F6"/>
                                        </Style>
                                    </Border.Styles>
                                    <!-- Grid: image / info / expiry / button (fixed bottom) -->
                                    <Grid RowDefinitions="Auto,*,Auto,Auto" Margin="12">
                                        <!-- Product Image -->
                                        <Border Grid.Row="0" Width="196" Height="160" CornerRadius="6" Background="#DBEAFE" ClipToBounds="True">
                                            <controls:CachedImage 
                                                SourceUrl="{Binding ImageURL}" 
                                                ImageHash="{Binding ImageHash}"
                                                ProductName="{Binding Name}"
                                                Stretch="UniformToFill"/>
                                        </Border>
                                        
                                        <!-- Product Info (flexible space) -->
                                        <StackPanel Grid.Row="1" Spacing="4" Margin="0,8,0,0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="14" 
                                                       TextWrapping="Wrap" MaxLines="2" 
                                                       Foreground="{DynamicResource SystemBaseHighColor}"/>
                                            <TextBlock Text="{Binding Category}" FontSize="12" 
                                                       Foreground="{DynamicResource SystemBaseMediumColor}"
                                                       TextWrapping="NoWrap"/>
                                            <TextBlock Text="{Binding DisplayPrice}" FontWeight="Bold" FontSize="14" 
                                                       Foreground="{DynamicResource SystemAccentColor}"/>
                                            
                                            <!-- Hidden badge -->
                                            <Border IsVisible="{Binding !IsAvailable}" 
                                                    Background="{DynamicResource SystemAltLowColor}" 
                                                    CornerRadius="4" Padding="4,2" HorizontalAlignment="Left">
                                                <TextBlock Text="Скрыт" FontSize="11" 
                                                           Foreground="{DynamicResource SystemBaseMediumColor}"/>
                                            </Border>
                                        </StackPanel>
                                        
                                        <!-- Stock status + expiry warning (fixed above button) -->
                                        <StackPanel Grid.Row="2" Spacing="2" Margin="0,4,0,4">
                                            <TextBlock Text="{Binding StockStatus}" FontSize="11" 
                                                       Foreground="{DynamicResource SystemBaseMediumColor}"/>
                                            <TextBlock Text="{Binding ExpiryText}" 
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="{Binding ExpiryColor}"
                                                       IsVisible="{Binding IsExpiringSoon}"/>
                                        </StackPanel>
                                        
                                        <!-- Edit Button - FIXED at bottom of card -->
                                        <Button Grid.Row="3"
                                                Content="✏️ Редактировать" 
                                                Command="{Binding $parent[ItemsControl].DataContext.StartEditCommand}"
                                                CommandParameter="{Binding}"
                                                Classes="Primary"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Center"
                                                Padding="8,6"
                                                FontSize="12"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Edit/Create Panel - Theme aware -->
            <Border Grid.Column="1" 
                   Background="{DynamicResource SystemAltMediumColor}" 
                   CornerRadius="5" 
                   Padding="15"
                   IsVisible="{Binding IsEditing}">
                <ScrollViewer>
                    <StackPanel Spacing="10">
                        <TextBlock Text="Редактирование товара" 
                                  FontSize="18" 
                                  FontWeight="Bold"
                                  HorizontalAlignment="Center"
                                  Foreground="{DynamicResource SystemBaseHighColor}"/>

                        <TextBox Watermark="Название*" Text="{Binding ProductName}"/>
                        <TextBox Watermark="Категория*" Text="{Binding Category}"/>
                        
                        <NumericUpDown Value="{Binding PricePerKg}" 
                                      FormatString="0.00"
                                      Minimum="0"
                                      Maximum="1000000"
                                      Watermark="Цена за кг"
                                      Background="{DynamicResource SystemAltHighColor}"
                                      Foreground="{DynamicResource SystemBaseHighColor}"/>
                        
                        <NumericUpDown Value="{Binding QuantityInStock}" 
                                      FormatString="0"
                                      Minimum="0"
                                      Maximum="1000000"
                                      Watermark="Количество"
                                      Background="{DynamicResource SystemAltHighColor}"
                                      Foreground="{DynamicResource SystemBaseHighColor}"/>
                        
                        <DatePicker SelectedDate="{Binding DeliveryDate, Converter={StaticResource DateTimeToDateTimeOffsetConverter}}"/>
                        
                        <DatePicker SelectedDate="{Binding ExpiryDate, Converter={StaticResource DateTimeToDateTimeOffsetConverter}}"/>
                        
                        <TextBox Watermark="Описание" 
                                Text="{Binding Description}"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                Height="80"/>
                        
                        <CheckBox Content="Доступен для заказа" 
                                 IsChecked="{Binding IsAvailable}"
                                 Foreground="{DynamicResource SystemBaseHighColor}"/>
                        
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Ед. измерения:" VerticalAlignment="Center" Foreground="{DynamicResource SystemBaseHighColor}"/>
                            <ComboBox SelectedItem="{Binding UnitType, Converter={StaticResource UnitDisplayConverter}}" MinWidth="100">
                                <ComboBox.Items>
                                    <system:String>кг</system:String>
                                    <system:String>шт</system:String>
                                </ComboBox.Items>
                            </ComboBox>
                        </StackPanel>

                        <!-- Image Upload Block -->
                        <Border CornerRadius="10"
                                Background="#F0FFF4"
                                Padding="12"
                                Margin="0,4,0,0">
                            <StackPanel Spacing="8">
                                <!-- Pending local file preview -->
                                <Border CornerRadius="8"
                                        ClipToBounds="True"
                                        Height="160"
                                        Background="#E0E0E0"
                                        IsVisible="{Binding PendingImagePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <Image x:Name="LocalPreviewImage" Stretch="UniformToFill"/>
                                </Border>

                                <!-- Current server image preview (only when no pending local file) -->
                                <Border CornerRadius="8"
                                        ClipToBounds="True"
                                        Height="160"
                                        Background="#E0E0E0"
                                        IsVisible="{Binding CurrentImageUrl, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <controls:CachedImage
                                        SourceUrl="{Binding CurrentImageUrl}"
                                        Stretch="UniformToFill"/>
                                </Border>

                                <!-- Upload button -->
                                <Button x:Name="PickImageButton"
                                        Click="PickImageButton_Click"
                                        IsEnabled="{Binding !IsUploadingImage}"
                                        Background="#E8F5E9"
                                        BorderBrush="#4CAF50"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="12,10"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="🖼"
                                                   FontSize="22"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,10,0"/>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="Загрузить изображение"
                                                       FontWeight="SemiBold"
                                                       Foreground="#2E7D32"
                                                       FontSize="13"/>
                                            <TextBlock FontSize="11"
                                                       Foreground="#555555"
                                                       Text="{Binding PendingImagePath, TargetNullValue='Нажмите для выбора файла', FallbackValue='Нажмите для выбора файла'}"/>
                                        </StackPanel>
                                        <ProgressBar Grid.Column="2"
                                                     IsIndeterminate="True"
                                                     IsVisible="{Binding IsUploadingImage}"
                                                     Width="20" Height="20"
                                                     VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>

                                <!-- Selected file name label -->
                                <TextBlock FontSize="11"
                                           Foreground="#388E3C"
                                           TextWrapping="Wrap"
                                           IsVisible="{Binding PendingImagePath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <Run Text="Выбрано: "/>
                                    <Run Text="{Binding PendingImagePath}"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Error Message -->
                        <TextBlock Text="{Binding ErrorMessage}" 
                                  Foreground="#DC2626" 
                                  TextWrapping="Wrap"/>

                        <!-- Buttons -->
                        <Grid ColumnDefinitions="*,*" Margin="0,10,0,0">
                            <Button Content="Сохранить" 
                                   Command="{Binding SaveProductCommand}"
                                   Classes="Primary"
                                   Margin="0,0,5,0"/>
                            <Button Grid.Column="1" 
                                   Content="Отмена" 
                                   Command="{Binding CancelEditCommand}"
                                   Margin="5,0,0,0"/>
                        </Grid>

                        <!-- Delete Button (only for edit) -->
                        <Button Content="Удалить товар" 
                               Command="{Binding DeleteProductCommand}"
                               CommandParameter="{Binding SelectedProduct}"
                               Background="#DC2626"
                               Foreground="White"
                               Margin="0,10,0,0"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Empty State -->
            <Border Grid.Column="0" 
                   Background="{DynamicResource SystemAltLowColor}" 
                   CornerRadius="5"
                   IsVisible="{Binding !HasProducts}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                    <TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center"/>
                    <TextBlock Text="Нет товаров" FontSize="18" HorizontalAlignment="Center" Foreground="{DynamicResource SystemBaseHighColor}"/>
                    <TextBlock Text="Нажмите кнопку «Добавить товар» чтобы создать первый товар" 
                              TextWrapping="Wrap"
                              TextAlignment="Center"
                              Foreground="{DynamicResource SystemBaseMediumColor}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
