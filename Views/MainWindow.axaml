<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AvaloniaApplication1.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="using:AvaloniaApplication1.Views"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        x:Class="AvaloniaApplication1.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Морепродукты - АРМ Сотрудника"
        Width="1024" Height="768"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <!-- Top Bar - Uses system accent color -->
        <Border Grid.Row="0" 
               Background="{DynamicResource SystemAccentColor}"
               Padding="15,10">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="15">
                    <!-- Navigation Buttons -->
                    <Button Content="📦 Товары" 
                           Command="{Binding NavigateToProductsCommand}"
                           IsVisible="{Binding ShowProducts}"
                           Background="{DynamicResource SystemAccentColor}"
                           Foreground="White"/>
                    
                    <Button Content="🛒 Заказы" 
                           Command="{Binding NavigateToOrdersCommand}"
                           IsVisible="{Binding ShowOrders}"
                           Background="{DynamicResource SystemAccentColor}"
                           Foreground="White"/>
                    
                    <Button Content="📋 Инвентаризация" 
                           Command="{Binding NavigateToInventoryCommand}"
                           IsVisible="{Binding ShowInventory}"
                           Background="{DynamicResource SystemAccentColor}"
                           Foreground="White"/>
                    
                    <Button Content="💬 Поддержка" 
                           Command="{Binding NavigateToSupportCommand}"
                           IsVisible="{Binding ShowSupport}"
                           Background="{DynamicResource SystemAccentColor}"
                           Foreground="White"/>
                    
                    <Button Content="👥 Сотрудники" 
                           Command="{Binding NavigateToStaffCommand}"
                           IsVisible="{Binding ShowStaffManagement}"
                           Background="{DynamicResource SystemAccentColor}"
                           Foreground="White"/>
                </StackPanel>

                <!-- User Info, Theme Toggle and Logout -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15" VerticalAlignment="Center">
                    <TextBlock Text="{Binding CurrentUser.FullName}" 
                              Foreground="White" 
                              FontSize="14"
                              FontWeight="SemiBold"
                              VerticalAlignment="Center"
                              IsVisible="{Binding IsLoggedIn}"/>
                    
                    <!-- Theme Toggle Button - Compact size -->
                    <Button Command="{Binding ToggleThemeCommand}"
                           VerticalAlignment="Center"
                           Background="Transparent"
                           Foreground="White"
                           Padding="2,1"
                           FontSize="10"
                           Width="24"
                           Height="24">
                        <TextBlock Text="{Binding IsDarkMode, Converter={StaticResource ThemeIconConverter}}"
                                  FontSize="12"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"/>
                    </Button>
                    
                    <Button Content="Выход" 
                           Command="{Binding LogoutCommand}"
                           IsVisible="{Binding IsLoggedIn}"
                           Background="{DynamicResource SystemAltMediumColor}"
                           Foreground="{DynamicResource SystemBaseHighColor}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area - Uses system theme background -->
        <Border Grid.Row="1" 
               Background="{DynamicResource SystemBaseLowColor}">
            <Grid>
                <!-- Current View Content - constrained to available space -->
                <ContentControl Content="{Binding CurrentView}" 
                               Margin="0,10,0,10"
                               VerticalAlignment="Stretch"
                               HorizontalAlignment="Stretch"/>
            </Grid>
        </Border>
    </Grid>
</Window>
